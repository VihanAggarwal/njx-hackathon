# Secrets
.env
*.key

# LLM response cache (regenerable, can be large)
.llm_cache/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
env/

# Downloaded / generated datasets (regenerable via loader)
eval/datasets/llmailinjections/
eval/datasets/agentdojo/
eval/datasets/multihop/
eval/datasets/benign/
eval/datasets/_downloads/

# Eval outputs: a REFERENCE RUN is committed so the repo is immediately viewable
# on GitHub (graphs render in the README, dashboard opens on double-click). The
# committed run is labeled MOCK in its manifest; re-running with a real API key
# overwrites it with live numbers. Nothing here is required to reproduce — it's
# all regenerable via run_benchmark.py + graphs.py.

# HuggingFace / model caches
.cache/
*.bin

# Trained prefilter artifacts (regenerable)
*.joblib

# Intermediate ProtectAI ONNX scoring sidecars (regenerable via clean venv)
eval/results/_hf_items.json
eval/results/_hf_scores_protectai.json
eval/results/_*.log

# OS
.DS_Store
Thumbs.db
